# Server Configuration
PORT=5175
NODE_ENV=development

# JWT Secret (generated for development)
# For production, generate a new secure random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# Database Configuration
# For Render: Use the DATABASE_URL provided by Render PostgreSQL
# For local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/remmogo
# Note: If password contains @ or other special chars, URL-encode them (%40 = @)
DATABASE_URL=postgresql://postgres:Pakobenson%4002@localhost:5432/remmogo

# CORS Origins (comma-separated list for production)
# Include all Vite dev ports (5173, 5174, etc.) and production URLs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://re-mmogo.vercel.app/