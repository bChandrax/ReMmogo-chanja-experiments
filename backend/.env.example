# Server Configuration
PORT=5175
NODE_ENV=production

# JWT Secret (generate a strong random string for production)
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration
# For Render: Use the DATABASE_URL provided by Render PostgreSQL
# For local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/remmogo
DATABASE_URL=postgresql://postgres:Pakobenson@02@localhost:5432/remmogo

# CORS Origins (comma-separated list for production)
# Example: https://re-mmogo.vercel.app,https://www.re-mmogo.com
ALLOWED_ORIGINS= http://localhost:5174/
